{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/bash

set -eufo pipefail

# Add Homebrew to PATH for the current session (required on Apple Silicon)
if [[ -f /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Install Chrome for Testing
# pnpm requires node on PATH; use mise exec to provide it in script context
mise exec node -- pnpm dlx @puppeteer/browsers install chrome@stable
{{ end }}
